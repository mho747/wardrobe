OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high

# Synology: set this to the NAS' LAN IP, never 0.0.0.0.
WARDROBE_BIND_ADDRESS=
WARDROBE_HOST_PORT=4173
WARDROBE_DATA_HOST_PATH=/volume1/docker/wardrobe/data
WARDROBE_BACKUP_HOST_PATH=/volume1/docker/wardrobe/backups
WARDROBE_UPDATE_STATE_HOST_PATH=/volume1/docker/wardrobe/update-state

# The deployment script sets this to the exact deployed Git revision.
WARDROBE_REVISION=

# The application always uses the mounted persistent data directory in containers.
WARDROBE_DATA_DIR=/app/data
WARDROBE_MODEL_REFERENCE=/app/data/model-reference.png

# Backups are encrypted only when the Synology volume itself is encrypted.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30

# This service checks GitHub only. It never installs an update itself.
GITHUB_REPOSITORY_URL=https://github.com/tandpfun/wardrobe.git
GITHUB_BRANCH=main
UPDATE_CHECK_INTERVAL_SECONDS=86400
